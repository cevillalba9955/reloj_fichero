{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fichadas RS596 - archivo de salida por sesión",
  "type": "object",
  "required": ["sessionId", "deviceHost", "devicePort", "startedAt", "endedAt", "declaredPendingCount", "receivedRecordCount", "status", "records"],
  "properties": {
    "sessionId": { "type": "string" },
    "deviceHost": { "type": "string" },
    "devicePort": { "type": "integer" },
    "startedAt": { "type": "string", "format": "date-time" },
    "endedAt": { "type": "string", "format": "date-time" },
    "declaredPendingCount": { "type": "integer", "minimum": 0 },
    "receivedRecordCount": { "type": "integer", "minimum": 0 },
    "status": { "type": "string", "enum": ["success", "error"] },
    "errorReason": { "type": ["string", "null"] },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rawHex", "recordTypeConstant", "verificationMethodCode", "verificationMethodLabel", "unresolvedFields"],
        "properties": {
          "rawHex": { "type": "string", "pattern": "^[0-9A-Fa-f]{40}$" },
          "recordTypeConstant": { "type": "string", "pattern": "^[0-9A-Fa-f]{8}$" },
          "verificationMethodCode": { "type": "string", "pattern": "^[0-9A-Fa-f]{8}$" },
          "verificationMethodLabel": {
            "type": "object",
            "required": ["value", "unconfirmed"],
            "properties": {
              "value": { "type": ["string", "null"] },
              "unconfirmed": { "type": "boolean", "const": true }
            }
          },
          "unresolvedFields": {
            "type": "object",
            "required": ["field0", "field1", "field4"],
            "properties": {
              "field0": { "type": "string", "pattern": "^[0-9A-Fa-f]{8}$", "description": "unconfirmed" },
              "field1": { "type": "string", "pattern": "^[0-9A-Fa-f]{8}$", "description": "unconfirmed, candidato a fecha/hora sin fórmula resuelta" },
              "field4": { "type": "string", "pattern": "^[0-9A-Fa-f]{8}$", "description": "unconfirmed" }
            }
          }
        }
      }
    }
  }
}
