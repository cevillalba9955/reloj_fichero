# Configuración del padrón de empleados activos desde Oracle/RRHH (feature 003).
# Solo se usa cuando el servicio se arranca con `--padron oracle`
# (por defecto `--padron archivo`, comportamiento de la feature 002).
#
# NUNCA se commitea un .env con valores reales: estos son solo placeholders.
# Las credenciales viajan EXCLUSIVAMENTE por entorno, nunca por argv (FR-004).

# Usuario Oracle de SOLO lectura, mínimo privilegio (Constitución, Principio II).
RRHH_ORACLE_USER=padron_ro

# Contraseña del usuario. Nunca se loguea ni aparece en mensajes de error (FR-005/Principio V).
RRHH_ORACLE_PASSWORD=cambiame

# Cadena de conexión EZCONNECT sugerida: host:puerto/servicio.
RRHH_ORACLE_CONNECT_STRING=oracle.rrhh.example.local:1521/RRHHPROD

# Vista de solo lectura provista por RRHH/DBA que ya devuelve los legajos activos.
# Identificador SQL estricto (permite `esquema.vista`).
RRHH_ORACLE_VISTA_PADRON=RRHH.V_PADRON_ACTIVOS

# Opcional: columna del legajo dentro de la vista (default LEGAJO). Identificador SQL sin punto.
RRHH_ORACLE_COLUMNA_LEGAJO=LEGAJO

# Opcional: tiempo máximo por consulta en milisegundos (default 10000). Entero > 0 (FR-009).
RRHH_ORACLE_TIMEOUT_MS=10000

# Columna de categoría del empleado dentro de la vista del padrón (feature 004).
# Identificador SQL sin punto. Se lee de solo lectura junto al legajo (Principio II).
RRHH_ORACLE_COLUMNA_CATEGORIA=CATEGORIA

# Opcional: columna del nombre del empleado dentro de la vista, para la IU.
# Identificador SQL sin punto. Si se define, el padrón incluye el nombre (dato
# personal: solo se usa para mostrar, nunca se loguea, Principio V). Si se omite,
# el nombre queda como null.
RRHH_ORACLE_COLUMNA_NOMBRE=NOMBRE


# ---------------------------------------------------------------------------
# Dominio de presentismo (spec 004) — cálculo de horas trabajadas por período.
# Se cargan al correr `npm run presentismo`.
# ---------------------------------------------------------------------------

# Ruta de la config de categorías/modalidades de este sistema (ver
# config/categorias.example.json). Default ./config/categorias.json.
PRESENTISMO_CATEGORIAS_CONFIG=./config/categorias.json

# Directorio del estado persistido (calendarios, correcciones, pausas) en JSON.
# Default ./data/presentismo.
PRESENTISMO_REPO_DIR=./data/presentismo

# Directorio de logs NDJSON del dominio de presentismo. Default ./logs.
PRESENTISMO_LOG_DIR=./logs

# Directorio del archivo acumulativo de fichadas por período (fuente del
# cálculo, poblado con `importar-fichadas`). Default <PRESENTISMO_REPO_DIR>/fichadas.
# Guarda rawHex para trazabilidad técnica (no es dato biométrico: es el frame del
# protocolo). Equivalente a --fichadas-archive-dir.
PRESENTISMO_FICHADAS_DIR=./data/presentismo/fichadas

# Directorio de los exports de sesión (fichadas-*.json) que produce el servicio
# de fichadas y de donde `importar-fichadas` toma los registros. Default ./output.
# Equivalente a --fichadas-dir.
FICHADAS_OUTPUT_DIR=./output

# Fuente del padrón (legajos activos + categoría): archivo | oracle.
# Default 'archivo': se opera sobre un snapshot local (sin conexión a la DB).
# Con 'oracle' cada comando consulta el padrón en vivo. Equivalente a --padron.
PRESENTISMO_PADRON=archivo

# Ruta del snapshot local del padrón, escrito por `sincronizar-padron`.
# Default <PRESENTISMO_REPO_DIR>/padron.json. Equivalente a --padron-file.
PRESENTISMO_PADRON_FILE=./data/presentismo/padron.json


# ---------------------------------------------------------------------------
# Servicio de consulta programada (spec 002) — parámetros del reloj RS596 y
# del sondeo. Todos son opcionales EXCEPTO FICHADAS_HOST (o pasar --host).
# Precedencia: argumento CLI > variable FICHADAS_* > default.
# Se cargan al correr `npm run servicio` (usa --env-file-if-exists=.env).
# ---------------------------------------------------------------------------

# IP del reloj RS596 (equivalente a --host). Requerido si no se pasa --host.
FICHADAS_HOST=192.168.1.82

# Puerto TCP del reloj (default 5005).
FICHADAS_PORT=5005

# Origen del padrón de empleados activos: archivo | oracle (default archivo, FR-013).
FICHADAS_PADRON=archivo

# Ruta del padrón local, solo si FICHADAS_PADRON=archivo (default ./config/active-employees.json).
# Acepta el formato legacy { "legajosActivos": [...] } o el snapshot de presentismo
# (spec 004) { "empleados": [{ "legajo" }] }. Para reutilizar el snapshot local del padrón:
#   FICHADAS_ROSTER_CONFIG=./data/presentismo/padron.json
FICHADAS_ROSTER_CONFIG=./config/active-employees.json

# NOTA (spec 005): el servicio persiste las fichadas obtenidas en el archivo acumulativo por
# período PRESENTISMO_FICHADAS_DIR (ver sección presentismo, default ./data/presentismo/fichadas),
# la MISMA fuente que consume `calcular`. Se puede fijar por --fichadas-archive-dir.

# Directorio de logs NDJSON (default ./logs).
FICHADAS_LOG_DIR=./logs

# Timeout por consulta TCP al reloj, en ms (default 5000). Entero > 0.
FICHADAS_TIMEOUT_MS=5000

# Cada cuánto se re-consulta al reloj mientras una ventana está abierta, en ms
# (default 300000 = 5 min — "repetición cada 5 minutos" del spec 002). Entero > 0.
FICHADAS_TICK_INTERVAL_MS=300000

# Cada cuánto el proceso imprime el resumen de estado, en ms (default 60000). Entero > 0.
FICHADAS_STATUS_INTERVAL_MS=600000

# Checkpoint de entrada: hora esperada (HH:MM) y duración de la ventana en minutos
# (defaults 07:00 / 30). La ventana es de un solo lado: [hora, hora + duración]
# (07:00 → 07:30 por defecto). El servicio sondea cada 5 min desde la hora de
# entrada hasta que cada legajo activo fiche o venzan los 30 min (spec 002,
# Clarifications 2026-07-14). El momento "salida" quedó fuera de alcance.
FICHADAS_ENTRADA_HORA=07:00
FICHADAS_ENTRADA_DURACION=30

# Handshake completo del protocolo (default false). true|1 para activarlo.
FICHADAS_FULL_HANDSHAKE=false

# Puerto del servidor de control HTTP local del servicio de fichadas (feature 010).
# Atado SIEMPRE a 127.0.0.1 (nunca a una interfaz externa); expone POST /tick para
# que la interfaz web dispare una consulta manual al reloj (misma sesión y
# single-flight del scheduler). Si NO se define, el servidor de control no se
# levanta (una instalación sin la página "Fichadas de hoy" no cambia su superficie
# de red). Valor sugerido: 5006. Equivalente a --control-port.
FICHADAS_CONTROL_PORT=5006


# ---------------------------------------------------------------------------
# Interfaz web (features 007/008/010) — servidor node src/web/server.js.
# ---------------------------------------------------------------------------

# URL del servidor de control local del servicio de fichadas, usada por el
# proceso web (rs956-web.service) para pedir una consulta manual al reloj
# (POST /tick) desde la página "Fichadas de hoy" (feature 010). Debe apuntar al
# FICHADAS_CONTROL_PORT del proceso de fichadas EN EL MISMO HOST (loopback).
# Default http://127.0.0.1:5006.
FICHADAS_CONTROL_URL=http://127.0.0.1:5006
