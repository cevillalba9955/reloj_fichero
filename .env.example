# Configuración del padrón de empleados activos desde Oracle/RRHH (feature 003).
# Solo se usa cuando el servicio se arranca con `--padron oracle`
# (por defecto `--padron archivo`, comportamiento de la feature 002).
#
# NUNCA se commitea un .env con valores reales: estos son solo placeholders.
# Las credenciales viajan EXCLUSIVAMENTE por entorno, nunca por argv (FR-004).

# Usuario Oracle de SOLO lectura, mínimo privilegio (Constitución, Principio II).
RRHH_ORACLE_USER=padron_ro

# Contraseña del usuario. Nunca se loguea ni aparece en mensajes de error (FR-005/Principio V).
RRHH_ORACLE_PASSWORD=cambiame

# Cadena de conexión EZCONNECT sugerida: host:puerto/servicio.
RRHH_ORACLE_CONNECT_STRING=oracle.rrhh.example.local:1521/RRHHPROD

# Vista de solo lectura provista por RRHH/DBA que ya devuelve los legajos activos.
# Identificador SQL estricto (permite `esquema.vista`).
RRHH_ORACLE_VISTA_PADRON=RRHH.V_PADRON_ACTIVOS

# Opcional: columna del legajo dentro de la vista (default LEGAJO). Identificador SQL sin punto.
RRHH_ORACLE_COLUMNA_LEGAJO=LEGAJO

# Opcional: tiempo máximo por consulta en milisegundos (default 10000). Entero > 0 (FR-009).
RRHH_ORACLE_TIMEOUT_MS=10000


# ---------------------------------------------------------------------------
# Servicio de consulta programada (spec 002) — parámetros del reloj RS596 y
# del sondeo. Todos son opcionales EXCEPTO FICHADAS_HOST (o pasar --host).
# Precedencia: argumento CLI > variable FICHADAS_* > default.
# Se cargan al correr `npm run servicio` (usa --env-file-if-exists=.env).
# ---------------------------------------------------------------------------

# IP del reloj RS596 (equivalente a --host). Requerido si no se pasa --host.
FICHADAS_HOST=192.168.1.82

# Puerto TCP del reloj (default 5005).
FICHADAS_PORT=5005

# Origen del padrón de empleados activos: archivo | oracle (default archivo, FR-013).
FICHADAS_PADRON=archivo

# Ruta del padrón local, solo si FICHADAS_PADRON=archivo (default ./config/active-employees.json).
FICHADAS_ROSTER_CONFIG=./config/active-employees.json

# Directorio de logs NDJSON (default ./logs).
FICHADAS_LOG_DIR=./logs

# Timeout por consulta TCP al reloj, en ms (default 5000). Entero > 0.
FICHADAS_TIMEOUT_MS=5000

# Cada cuánto se re-consulta al reloj mientras una ventana está abierta, en ms
# (default 300000 = 5 min — "repetición cada 5 minutos" del spec 002). Entero > 0.
FICHADAS_TICK_INTERVAL_MS=300000

# Cada cuánto el proceso imprime el resumen de estado, en ms (default 60000). Entero > 0.
FICHADAS_STATUS_INTERVAL_MS=60000

# Checkpoint de entrada: hora esperada (HH:MM) y margen en minutos (defaults 07:00 / 30).
FICHADAS_ENTRADA_HORA=07:00
FICHADAS_ENTRADA_MARGEN=30

# Checkpoint de salida: hora esperada (HH:MM) y margen en minutos (defaults 16:00 / 30).
FICHADAS_SALIDA_HORA=16:00
FICHADAS_SALIDA_MARGEN=30

# Handshake completo del protocolo (default false). true|1 para activarlo.
FICHADAS_FULL_HANDSHAKE=false
